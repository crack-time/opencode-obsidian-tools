{
  "name": "opencode-obsidian",
  "version": "1.0.7",
  "description": "OpenCode plugin for Obsidian vault integration via CLI",
  "type": "module",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "esbuild opencode-obsidian.ts --bundle --platform=node --format=esm --external:@opencode-ai/plugin --outfile=dist/index.js && rm -rf dist/skills && cp -r skills dist/skills",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "obsidian",
    "plugin",
    "vault",
    "notes"
  ],
  "author": "Chen",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crack-time/opencode-obsidian.git"
  },
  "bugs": {
    "url": "https://github.com/crack-time/opencode-obsidian/issues"
  },
  "homepage": "https://github.com/crack-time/opencode-obsidian#readme"
}
